---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Conduit Docs" noindex={true}>
  <section class="container py-16">
    <h1 class="text-4xl mb-4">Conduit Docs — v2 scaffold</h1>
    <p class="text-[var(--muted)] max-w-2xl mb-6">
      This is the parallel-build scaffold for the Path B migration off Starlight.
      The header above and footer below are ported from the gateway docs
      (<a href="https://mcp.wyretechnology.com" class="text-accent underline">mcp.wyretechnology.com</a>)
      for brand parity. Content migration begins with later epics.
    </p>
    <p class="text-[var(--muted)] text-sm">
      Tracker: <a href="https://linear.app/wyre-ai/issue/WYREAI-101/" class="text-accent underline">WYREAI-101</a>
      &nbsp;·&nbsp;
      Epic 1: <a href="https://linear.app/wyre-ai/issue/WYREAI-102/" class="text-accent underline">WYREAI-102</a>
    </p>
  </section>
</BaseLayout>

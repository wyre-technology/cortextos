---
// Conduit docs footer. Ported from the gateway docs Footer.astro
// (wyre-technology/msp-claude-plugins/docs/src/components/Footer.astro)
// for brand parity, with conduit-specific links.

const baseUrl = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] mt-auto">
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <a href={baseUrl} class="flex items-center gap-2 font-semibold text-lg mb-4">
          <svg class="w-8 h-8 text-accent" viewBox="0 0 32 32" fill="currentColor" role="img" aria-label="Conduit logo">
            <path d="M16 2L2 9l14 7 14-7-14-7zM2 23l14 7 14-7M2 16l14 7 14-7"/>
          </svg>
          <span>Conduit Docs</span>
        </a>
        <p class="text-[var(--muted)] max-w-md">
          Conduit is the white-label MSP channel gateway that connects AI agents to the vendor MCP servers MSPs already rely on.
        </p>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Documentation</h3>
        <ul class="space-y-2 text-[var(--muted)]">
          <li><a href={`${baseUrl}getting-started/`} class="hover:text-[var(--text)]">Getting Started</a></li>
          <li><a href={`${baseUrl}guides/`} class="hover:text-[var(--text)]">Guides</a></li>
          <li><a href={`${baseUrl}api/`} class="hover:text-[var(--text)]">API Reference</a></li>
          <li><a href={`${baseUrl}architecture/`} class="hover:text-[var(--text)]">Architecture</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Conduit</h3>
        <ul class="space-y-2 text-[var(--muted)]">
          <li>
            <a href="https://github.com/wyre-technology/conduit" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)]">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://github.com/wyre-technology/conduit/issues" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)]">
              Report an Issue
            </a>
          </li>
          <li>
            <a href="https://wyre.ai" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)]">
              WYRE Technology
            </a>
          </li>
          <li>
            <a href="mailto:hello@wyre.ai" class="hover:text-[var(--text)]">
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--border)] mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-[var(--muted)] text-sm">
      <p>&copy; {currentYear} WYRE Technology. Built with Astro.</p>
      <div class="flex gap-6">
        <a href="https://docs.ourterms.live/WYRE/AI-Attachment.pdf" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)] transition-colors">AI MSA</a>
        <a href={`${baseUrl}sla/`} class="hover:text-[var(--text)] transition-colors">SLA</a>
        <a href="https://wyre.ai/privacy/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)] transition-colors">Privacy</a>
      </div>
    </div>
  </div>
</footer>

---
// Emits the FAQPage JSON-LD for a docs slug. The schema text is the visible
// rendered Q/A (markdown-normalized) and is `<`-escaped at build, so an
// authored answer can never break out of the <script>. See ../lib/faq.ts.
//
// faq.ts lives at docs/src/lib/ (NOT repo-root src/) so it resolves inside
// the docs-builder Docker stage, whose context is WORKDIR /docs + COPY
// docs/src ./src — a repo-root ../../../src import escaped that context and
// reddened main on #249 (the docker docs-build is not a PR check).
import { buildFaqJsonLd } from '../lib/faq';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const jsonLd = buildFaqJsonLd(slug);
---

<script type="application/ld+json" is:inline set:html={jsonLd} />

# =============================================================================
# MCP Gateway Platform — Environment Variables
# =============================================================================
# Copy to .env and fill in values for your deployment.

# --- Server ---
PORT=8080
HOST=0.0.0.0
BASE_URL=http://localhost:8080
LOG_LEVEL=info                    # debug | info | warn | error

# --- Security (REQUIRED in production) ---
MASTER_KEY=                       # 64 hex chars (32 bytes) — encrypts credentials
JWT_SECRET=                       # 64 hex chars (32 bytes) — signs JWTs

# --- Database ---
DATABASE_URL=postgres://gateway:gateway@localhost:5432/gateway

# --- Auth Provider ---
AUTH_PROVIDER=auth0               # 'auth0' or 'azure-ad'

# --- Auth0 OIDC (when AUTH_PROVIDER=auth0) ---
AUTH0_DOMAIN=                     # e.g. "your-tenant.us.auth0.com"
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=               # e.g. "https://your-domain.com/auth/callback"

# --- Azure AD OIDC (when AUTH_PROVIDER=azure-ad) ---
AZURE_AD_TENANT_ID=              # optional — leave empty for multi-tenant (common)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_CALLBACK_URL=           # e.g. "https://your-domain.com/auth/callback"

# --- Stripe Billing (optional — skip for managed services contracts) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# --- Token Lifetimes ---
ACCESS_TOKEN_TTL=3600             # seconds (default: 1 hour)
REFRESH_TOKEN_TTL=2592000         # seconds (default: 30 days)
AUTH_CODE_TTL=300                 # seconds (default: 5 minutes)

# --- Admin ---
ADMIN_API_KEY=                    # Protects admin endpoints (waitlist export, plan set)
ALPHA_INVITE_CODES=               # Comma-separated invite codes for pro plan

# --- Waitlist ---
WAITLIST_NOTIFY_URL=              # Discord/Slack webhook for new signups

# --- Vendor Monitoring ---
MONITOR_WEBHOOK_URL=              # Discord/Slack webhook for health alerts
MONITOR_INTERVAL_MS=60000         # Health check interval (default: 60s)

# --- Brand Configuration (white-label) ---
BRAND_NAME=                       # default: "Wyre Technology"
BRAND_TAGLINE=                    # default: "MCP Gateway for MSPs"
BRAND_LOGO_URL=                   # default: "/assets/logo.svg"
BRAND_SUPPORT_URL=                # default: ""
BRAND_DOCS_URL=                   # default: "/"
BRAND_ISSUES_URL=                 # default: GitHub issues URL
BRAND_PRIMARY_COLOR=              # default: "#2563eb"
BRAND_DOMAIN=                     # default: derived from BASE_URL

# --- Plan Catalog (optional JSON override) ---
# PLAN_CATALOG='[{"slug":"free","name":"Free","vendorLimit":3,"rateLimitPerHour":100,"teamFeatures":false,"logShipping":false,"promptCapture":false,"maxMembers":1},{"slug":"pro","name":"Pro","vendorLimit":"Infinity","rateLimitPerHour":1000,"teamFeatures":true,"logShipping":true,"promptCapture":true,"maxMembers":"Infinity"}]'

# --- Feature Flags ---
FEATURE_DASHBOARD=true            # set to "false" to disable dashboard
FEATURE_PROMPT_CAPTURE=true       # set to "false" to disable prompt capture

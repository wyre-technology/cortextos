{
  "name": "@wyre-technology/mcp-gateway-platform",
  "version": "0.0.0-semantically-released",
  "private": true,
  "description": "MCP Gateway Platform \u2014 white-label AI tool gateway for managed service providers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "migrate:from-mcp-gateway": "tsx scripts/migrate-from-mcp-gateway.ts",
    "backfill:invitation-tokens": "tsx scripts/backfill-invitation-tokens.ts"
  },
  "keywords": [
    "mcp",
    "gateway",
    "oauth",
    "msp",
    "claude",
    "white-label",
    "platform"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/reply-from": "^12.6.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "openid-client": "^6.8.4",
    "postgres": "^3.4.9",
    "samlify": "^2.13.1",
    "scim-patch": "^0.9.1",
    "stripe": "^22.1.1",
    "ws": "^8.20.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
